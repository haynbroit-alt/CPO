FROM python:3.11-slim

WORKDIR /app

# Copy everything before install — hatchling needs sios/ to build the package
COPY . .
RUN pip install --no-cache-dir ".[cashflow]"

RUN useradd -m appuser && chown -R appuser:appuser /app
USER appuser

RUN mkdir -p reports

EXPOSE 8080

CMD ["sh", "-c", "uvicorn app.cashflow:app --host 0.0.0.0 --port ${PORT:-8080}"]
