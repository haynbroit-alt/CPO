# Copy to .env and adjust values before running

# Consensus
QUORUM_THRESHOLD=0.66
STABILITY_WINDOW_SEC=30

# Sandbox
EXECUTION_TIMEOUT=10

# Docker images (override per world if needed)
IMAGE_LLM=proof-protocol/sandbox:latest
IMAGE_SYMBOLIC=proof-protocol/symbolic:latest
IMAGE_NEURO=proof-protocol/neuro:latest
IMAGE_BAYESIAN=proof-protocol/bayesian:latest
IMAGE_EVOLUTIONARY=proof-protocol/evolutionary:latest
IMAGE_FORMAL=proof-protocol/formal:latest
IMAGE_MULTIMODAL=proof-protocol/multimodal:latest

# Crypto
PRIVATE_KEY_FILE=node_key.pem

# Storage
LEDGER_FILE=ledger.jsonl

# Brain (LLM code generator for /ask endpoint)
ANTHROPIC_API_KEY=sk-ant-...
BRAIN_MODEL=claude-haiku-4-5

# Executor backend: "docker" (default, needs Docker socket) or "subprocess" (Render / no-Docker)
EXECUTOR_BACKEND=docker
