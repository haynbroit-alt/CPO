# SIOS Cashflow — environment variables
# Copy to .env and fill in your values

# ── Stripe (required for live payments) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────
BASE_URL=http://localhost:8080
AUDIT_PRICE_CENTS=4900        # 4900 = €49.00

# ── Reports ───────────────────────────────────────────────────────
SIOS_REPORTS_DIR=./reports    # PDF storage directory

# ── Email delivery (pick one) ─────────────────────────────────────
# Option 1: Resend (recommended — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM=SIOS Audit <audit@yourdomain.com>

# Option 2: SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
